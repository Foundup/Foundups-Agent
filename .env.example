BLOCKCHAIN_ENABLED=False
TOKEN_CONTRACT_ADDRESS=0x...
RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_ID
AGENT_WALLET_PRIVATE_KEY=YOUR_AGENT_WALLET_PRIVATE_KEY_IF_ENABLED

