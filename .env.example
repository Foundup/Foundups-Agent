# FoundUps Agent Environment Configuration
# Rename this file to .env and fill in your values
# Follow the Windsurf Protocol for secure configuration management

# =============================================
# Core Configuration
# =============================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Managed env loader (main.py):
# - 1: auto-build/load .env.managed from .env (recommended)
# - 0: load .env directly (legacy behavior)
FOUNDUPS_ENV_MANAGED=1
# Security defaults:
# - keep normalized env in-memory only (no disk copy)
# - purge stale .env.managed if found
FOUNDUPS_ENV_MANAGED_DISK_COPY=0
FOUNDUPS_ENV_MANAGED_PURGE_COPY=1
# Startup env hygiene check (warn on duplicates/orphans from managed parser stats).
FOUNDUPS_ENV_PREFLIGHT=1
# Set to 1 to hard-block startup when duplicates/orphans are detected.
FOUNDUPS_ENV_PREFLIGHT_ENFORCED=0

# Agent's greeting message for livestreams
AGENT_GREETING_MESSAGE="Hello everyone! reporting for duty. I'm here to listen and learn (and maybe crack a joke). Beep boop!"

# =============================================
# Core Feature Flags (Switchboard)
# =============================================
# These are safe toggles to isolate systems without code edits.
FOUNDUPS_ENABLE_PATTERN_MEMORY=true
FOUNDUPS_ENABLE_WRE=true
FOUNDUPS_ENABLE_WRE_MONITOR=true
FOUNDUPS_ENABLE_QWEN=true
FOUNDUPS_ENABLE_SELF_IMPROVEMENT=true
FOUNDUPS_ENABLE_SHORTS_COMMANDS=true
FOUNDUPS_DISABLE_SHORTS_COMMANDS=false
FOUNDUPS_ENABLE_KEY_HYGIENE=true
INSTANCE_LOCK_AUTO_CLEAN_STALE=true

# Key hygiene prompt tuning (rotate keys proactively; prevent repeated nagging)
FOUNDUPS_KEY_HYGIENE_ROTATE_DAYS=30
FOUNDUPS_KEY_HYGIENE_PROMPT_COOLDOWN_HOURS=12
FOUNDUPS_KEY_HYGIENE_OPEN_BROWSER=true
FOUNDUPS_KEY_HYGIENE_POPUP=false

# HoloIndex performance + output controls
HOLO_SKIP_MODEL=false
HOLO_SILENT=false
HOLO_VERBOSE=false
HOLO_OFFLINE=false
HOLO_DISABLE_PIP_INSTALL=false
HOLO_BREADCRUMB_ENABLED=true
HOLO_BREADCRUMB_LOGS=true
HOLO_REWARD_VARIANT=A
HOLO_SSD_PATH=E:/HoloIndex
HOLO_CACHE_PATH=E:/HoloIndex/cache
HOLO_MODEL_ROOT=E:/HoloIndex/models

# Central local model routing (single source of truth for local LLM files)
# Model root with role-based folders:
#   triage -> gemma-270m
#   general -> qwen3-4b
#   code -> qwen-coder-7b
LOCAL_MODEL_ROOT=E:/LM_studio/models/local
LOCAL_MODEL_TRIAGE_DIR=E:/LM_studio/models/local/gemma-270m
LOCAL_MODEL_GENERAL_DIR=E:/LM_studio/models/local/qwen3-4b
# Optional Qwen3.5 upgrade target:
# LOCAL_MODEL_GENERAL_DIR=E:/LM_studio/models/local/qwen3.5-4b
LOCAL_MODEL_CODE_DIR=E:/LM_studio/models/local/qwen-coder-7b

# Optional explicit GGUF file overrides (blank = auto-discover best .gguf in dir)
LOCAL_MODEL_TRIAGE_PATH=
LOCAL_MODEL_GENERAL_PATH=
LOCAL_MODEL_CODE_PATH=

# Keep legacy fallback paths disabled by default.
# Set true only if you intentionally want old E:/HoloIndex or E:/LLM_Models fallbacks.
LOCAL_MODEL_ENABLE_LEGACY_FALLBACK=false

# Backward-compatible alias used by older modules (can be file OR directory)
HOLO_QWEN_MODEL=E:/LM_studio/models/local/qwen-coder-7b
HOLO_QWEN_MAX_TOKENS=512
HOLO_QWEN_TEMPERATURE=0.2
HOLO_QWEN_CACHE=true
HOLO_QWEN_TELEMETRY=E:/HoloIndex/indexes/holo_usage.json
HOLO_LLM_BASE_URL=
HOLO_LLM_API_KEY=
HOLO_AGENT_ID=
0102_HOLO_ID=
HOLO_MCP_ENABLED=true
HOLO_MCP_WARNINGS=true
HOLO_MONITOR_INTERVAL=5.0
HOLO_MONITOR_HEARTBEAT=60.0
HOLO_PATTERN_MEMORY_LOGS=true
FOUNDUPS_HOLO_AUTO_INDEX=false
FOUNDUPS_HOLO_AUTO_INDEX_MAX_HOURS=6
FOUNDUPS_CLEAR_SCREEN=false
AI_OVERSEER_BREADCRUMBS=true

# OpenClaw / IronClaw conversation runtime
# Runtime profile:
# - openclaw: normal operation (default)
# - ironclaw: ironclaw-focused operation
# - zeroclaw: fail-closed (external LLM OFF, mutating intents downgraded)
OPENCLAW_RUNTIME_PROFILE=openclaw
OPENCLAW_CONVERSATION_BACKEND=openclaw
OPENCLAW_NO_API_KEYS=0
OPENCLAW_ALLOW_EXTERNAL_LLM=1
OPENCLAW_OLLAMA_MODEL=qwen2.5-coder:7b
OPENCLAW_ALLOW_IRONCLAW_FALLBACK=0
# IronClaw strict routing:
# - When backend=ironclaw and strict=1, OpenClaw will NOT silently fall back
#   to local models unless OPENCLAW_IRONCLAW_ALLOW_LOCAL_FALLBACK=1.
OPENCLAW_IRONCLAW_STRICT=1
OPENCLAW_IRONCLAW_ALLOW_LOCAL_FALLBACK=0
# 0102 taxonomy labels for deterministic "which model/species/genus are you?" answers
# Casing convention: only the "E" in Ex.machina is uppercase; other labels lowercase.
# model_family = epoch family label (example: davinci).
# model_name supports "{model}" token and expands to active runtime model.
OPENCLAW_IDENTITY_GENUS=Ex.machina
OPENCLAW_IDENTITY_MODEL_FAMILY=davinci
OPENCLAW_IDENTITY_MODEL_NAME={model}
OPENCLAW_IDENTITY_MODEL_CATALOG=qwen2.5,qwen3,qwen3.5,ui_tars1.5,grok4,codex5.3,opus4.6,sonnet4.6,gemini3pro
OPENCLAW_IDENTITY_PROTOCOL=wsp_00
# Inject WSP_00 boot context into local conversation system prompts.
# mode: compact | full | off
OPENCLAW_WSP00_BOOT=1
OPENCLAW_WSP00_BOOT_MODE=compact
# Optional file override for WSP_00 boot prompt text (trimmed to 4000 chars)
# Example: modules/communication/moltbot_bridge/workspace/WSP00_BOOT_PROMPT.txt
OPENCLAW_WSP00_PROMPT_FILE=
# Backward-compat alias (optional): OPENCLAW_IDENTITY_MODEL_LINEAGE
# Backward-compat alias (optional): OPENCLAW_IDENTITY_SPECIES=davinci+{model}
IRONCLAW_BASE_URL=http://127.0.0.1:3000
IRONCLAW_MODEL=local/qwen-coder-7b
IRONCLAW_AUTH_TOKEN=
IRONCLAW_TIMEOUT_SEC=15
IRONCLAW_NO_API_KEYS=1
IRONCLAW_START_CMD=
WRE_ENABLE_IRONCLAW_WORKER=1
# Simulator Qwen backend route: local | ironclaw | wre_ironclaw
SIM_QWEN_BACKEND=local

# OpenClaw startup/skill security hardening.
# Set OPENCLAW_24X7=1 for unattended always-on mode. This makes startup
# security preflight strict by default (unless overridden explicitly).
OPENCLAW_24X7=0
OPENCLAW_SECURITY_PREFLIGHT=1
OPENCLAW_SECURITY_PREFLIGHT_ENFORCED=0
OPENCLAW_SECURITY_PREFLIGHT_FORCE=0
OPENCLAW_SECURITY_MONITOR_ENABLED=1
OPENCLAW_SECURITY_MONITOR_INTERVAL_SEC=300

# Dependency/CVE startup preflight (Python/Node/Rust).
OPENCLAW_DEP_SECURITY_PREFLIGHT=1
OPENCLAW_DEP_SECURITY_PREFLIGHT_ENFORCED=0
OPENCLAW_DEP_SECURITY_PREFLIGHT_FORCE=0
OPENCLAW_DEP_SECURITY_PREFLIGHT_TTL_SEC=21600
OPENCLAW_DEP_SECURITY_REQUIRE_TOOLS=0
OPENCLAW_DEP_SECURITY_MAX_CRITICAL=0
OPENCLAW_DEP_SECURITY_MAX_HIGH=0
OPENCLAW_DEP_SECURITY_MAX_UNKNOWN=0
OPENCLAW_DEP_SECURITY_CHECK_NODE=1
OPENCLAW_DEP_SECURITY_NODE_LOCK_SCOPE=all
OPENCLAW_DEP_SECURITY_CHECK_RUST=1

# Brain artifact memory preflight (WSP knowledge reasoning traces).
BRAIN_ARTIFACT_PREFLIGHT=1
BRAIN_ARTIFACT_PREFLIGHT_ENFORCED=0
BRAIN_ARTIFACT_PREFLIGHT_FORCE=0

# Cisco skill scanner policy.
OPENCLAW_SKILL_SCAN_REQUIRED=1
OPENCLAW_SKILL_SCAN_ENFORCED=1
OPENCLAW_SKILL_SCAN_MAX_SEVERITY=medium
OPENCLAW_SKILL_SCAN_TTL_SEC=900
# Set to 1 to scan on every mutating/skill-driven intent (no cache reuse).
OPENCLAW_SKILL_SCAN_ALWAYS=0

# Signed skill-manifest policy (workspace/skills).
OPENCLAW_SKILL_MANIFEST_REQUIRED=1
OPENCLAW_SKILL_MANIFEST_ENFORCED=1
OPENCLAW_SKILL_MANIFEST_VERIFY_SIGNATURE=0
OPENCLAW_SKILL_MANIFEST_ALLOW_EXTRA=0
OPENCLAW_SKILL_MANIFEST_FILE=
OPENCLAW_SKILL_MANIFEST_HMAC_KEY=

# 0102 continuous daemon self-audit loop.
CENTRAL_DAEMON_ENABLED=1
OPENCLAW_SELF_AUDIT_ENABLED=1
OPENCLAW_SELF_AUDIT_INTERVAL_SEC=5
OPENCLAW_SELF_AUDIT_LOG_GLOBS=holo_index/logs/**/*.log;logs/**/*.log;holo_index/logs/telemetry/**/*.jsonl
OPENCLAW_SELF_AUDIT_AUTO_FIX=1
OPENCLAW_SELF_AUDIT_ALLOWED_FIXES=start_ironclaw_gateway,diagnose_microphone_device,verify_dae_event_store
OPENCLAW_SELF_AUDIT_ALLOW_SHELL_START_CMD=0
OPENCLAW_SELF_AUDIT_TELEMETRY=1
OPENCLAW_SELF_AUDIT_ESCALATE_AFTER=3
OPENCLAW_SELF_AUDIT_ESCALATION_WINDOW_SEC=900
OPENCLAW_SELF_AUDIT_ESCALATION_COOLDOWN_SEC=600
OPENCLAW_SELF_AUDIT_ESCALATE_CMD=
OPENCLAW_SELF_AUDIT_ESCALATE_ALLOW_SHELL_CMD=0
OPENCLAW_SELF_AUDIT_FIX_COOLDOWN_SEC=120
OPENCLAW_SELF_AUDIT_DEDUPE_WINDOW_SEC=120
OPENCLAW_SELF_AUDIT_MAX_READ_BYTES=65536

# WRE per-skill Cisco scan gate (pre-execute).
WRE_SKILL_SCAN_REQUIRED=1
WRE_SKILL_SCAN_ENFORCED=1
WRE_SKILL_SCAN_ALWAYS=0
WRE_SKILL_SCAN_TTL_SEC=900
WRE_SKILL_SCAN_MAX_SEVERITY=medium

# CodeAct strict shell policy.
WRE_CODEACT_STRICT=1

