LINKEDIN_DEFAULT_COMPANY=foundups
LINKEDIN_ACCOUNTS_JSON={"foundups":"1263645","autonomouswall":"35532191","esingularity":"2199715","lnrepublicanvoters":"2199715","aiharmonic":"96096638","foundups100x100":"64659868","bitcloutfork":"76734687","decentralizedcrypto":"33433199","move2japan":"104834798","undaodu":"68706058","eduit":"377243"}

# =============================================
# Local Automation (Chrome + LM Studio / UI-TARS)
# =============================================
# Chrome DevTools port (shared browser automation session)
# Port 9222: YouTube Studio comment engagement (studio.youtube.com)
FOUNDUPS_CHROME_PORT=9222
# Port 9223: YouTube Live Chat (!party reactions, future direct chat injection)
FOUNDUPS_LIVECHAT_CHROME_PORT=9223
# Optional explicit Chrome path/profile (used by dependency launcher)
CHROME_PATH=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe
CHROME_PROFILE_PATH=O:/Foundups-Agent/modules/platform_integration/browser_profiles/youtube_move2japan/chrome

# LM Studio OpenAI-compatible API (for UI-TARS vision model)
LM_STUDIO_PORT=1234
# LM_STUDIO_PATH can be auto-detected; set it explicitly if needed
LM_STUDIO_PATH=E:\\LM_studio\\LM Studio\\LM Studio.exe

# YouTube Studio comment engagement (runs at YouTube DAE startup)
COMMUNITY_STARTUP_ENGAGE=true
# 0 = unlimited (clear the inbox); set 1-3 for quick smoke tests
COMMUNITY_STARTUP_MAX_COMMENTS=0
# Optional: override which channel's Studio inbox is processed (defaults to CHANNEL_ID)
COMMUNITY_CHANNEL_ID=
# Safety timeout (seconds) for unlimited runs
COMMUNITY_UNLIMITED_TIMEOUT=1800
# Stream subprocess logs (prevents “silent hang” confusion)
COMMUNITY_DEBUG_SUBPROCESS=true

# =============================================
# YouTube Automation Safety Switchboard
# =============================================
# Use these flags to isolate/disable automation behaviors if YouTube shows
# an "automation detected" warning. Default values preserve current behavior.

# Master switch for all YouTube automation actions (UI + API actions)
YT_AUTOMATION_ENABLED=true
# Optional run id for correlating logs across modules/subprocesses (auto-generated if empty)
YT_AUTOMATION_RUN_ID=

# Emergency stop file: when this path exists, *all* automated actions are blocked (safety circuit breaker)
# Create:  New-Item -ItemType File -Force memory/STOP_YT_AUTOMATION
# Remove:  Remove-Item memory/STOP_YT_AUTOMATION
YT_AUTOMATION_STOP_FILE=memory/STOP_YT_AUTOMATION

# Optional: disable auto-launching Chrome/LM Studio at YouTube DAE startup (use manual launch / --deps instead)
YT_DEPS_AUTO_LAUNCH=true

# Optional: override channel rotation (comma-separated channel IDs). Blank = default rotation list.
YT_CHANNELS_TO_CHECK=
# Optional: safe test channel id (included in default rotation only if set)
TEST_CHANNEL_ID=

# Comment inbox engagement (UI automation: like/heart/reply)
YT_COMMENT_ENGAGEMENT_ENABLED=true
# Comma-separated action list (default = like,heart,reply)
YT_COMMENT_ACTIONS=like,heart,reply
# Optional per-action overrides (set to true/false to override YT_COMMENT_ACTIONS)
YT_COMMENT_LIKE_ENABLED=
YT_COMMENT_HEART_ENABLED=
YT_COMMENT_REPLY_ENABLED=
# Reply behavior
YT_COMMENT_REPLY_TEXT=
YT_COMMENT_INTELLIGENT_REPLY_ENABLED=true
# Reply generation router (IntelligentReplyGenerator)
# true = use Skill 0/1/2 router (recommended); false = legacy monolithic fallback
USE_SKILL_ROUTER=true
# If true, append debug tags to replies (commenter type + WSP44 semantic state)
YT_REPLY_DEBUG_TAGS=false

# --- Reply Generation LLM Chain Switches (2025-12-30) ---
# These switches disable specific components of the reply generation pipeline
# LLM chain order: Grok → LM Studio → Qwen Engine → BanterEngine (templates)

# Disable BanterEngine template fallbacks (force LLM-only replies, skip if all LLMs fail)
DISABLE_BANTER_ENGINE=false

# Disable local Qwen llama.cpp inference (step 3 in chain)
DISABLE_QWEN_ENGINE=false

# Disable Gemma-based content analysis (extracts topic/sentiment/key points from comments)
# When disabled, LLM prompts won't include content analysis context
DISABLE_CONTENT_ANALYZER=false

# Nested reply engagement (replies to replies in comment threads)
# If enabled, 0102 will engage with ongoing conversations within threads
# Automatically skips threads where Move2Japan already replied (avoids spam)
YT_ENGAGE_NESTED_REPLIES=false
# Maximum nested replies to process per thread (prevents excessive engagement)
YT_MAX_NESTED_REPLIES=5

# --- DAEmon Orchestration Switches (2026-03-10) ---
# Master switches for each processing phase. Set to false to skip that phase.
# Useful for debugging, isolating failures, or running specific phases only.

# Phase 1: Comment engagement (Chrome + Edge)
YT_COMMENTS_ENABLED=true

# Phase 2: Video indexing (Chrome only - Move2Japan LIVES for Digital Twin)
YT_VIDEO_INDEXING_ENABLED=false

# Phase 3: Shorts scheduling (both browsers)
YT_SHORTS_SCHEDULING_ENABLED=true
# Cap videos per channel per cycle (prevents runaway scheduling)
YT_SHORTS_PER_CYCLE=5
YT_SHORTS_PHASE3_TIMEOUT=3600

# Phase 4: LinkedIn feed engagement (Edge only - triggered after YouTube tasks)
# antifaFM completion triggers LinkedIn feed commenting
LN_FEED_ENGAGEMENT_ENABLED=false
LN_FEED_MODE=like_reply
LN_FEED_MAX_POSTS=10
LN_FEED_MAX_ENGAGEMENTS=3
LN_FEED_DRY_RUN=true
LN_FEED_AGENTIC=true

# --- Browser Port Configuration ---
# Separate Chrome instances for parallel operation (zero conflicts)
# Comment engagement: port 9222 (run launch_chrome_livechat.bat)
# LinkedIn/X posting: port 9223 (run launch_chrome_social_media.bat)
FOUNDUPS_CHROME_PORT=9222
SOCIAL_MEDIA_CHROME_PORT=9223

# Live chat messaging (YouTube API: liveChatMessages.insert)
YT_LIVECHAT_SEND_ENABLED=true
# If true, log but do not send live chat messages
YT_LIVECHAT_DRY_RUN=false
# Optional: force a specific OAuth credential set for YouTube DAE (blank=auto-rotate)
YT_FORCE_CREDENTIAL_SET=
# Optional: override persona selection for live chat responses (auto/foundups/undaodu/move2japan/antifafm)
YT_ACTIVE_PERSONA=auto

# Live chat UI automation (Selenium/UI-TARS actions inside the browser)
# Examples: reaction spam (!party), (optional) vision-based chat sending.
YT_LIVECHAT_UI_ACTIONS_ENABLED=true
YT_PARTY_REACTIONS_ENABLED=true

# Optional: allow/disallow internal announcements (e.g., comment engagement summaries) in live chat
YT_LIVECHAT_ANNOUNCEMENTS_ENABLED=true

# Stream detection (HTTP scraping)
YT_STREAM_SCRAPING_ENABLED=true
# Stream detection: scan all channels for concurrent live streams (default true)
YT_SCAN_ALL_LIVE=true

# TRUE NO-API MODE: Skip API verification entirely (rely 100% on scraping indicators)
# Default: true (use API confirmation for accuracy)
# Set to false for pure no-API detection (when API is disabled/expired)
YT_STREAM_API_VERIFY=true

# Stream detection log verbosity (true = more INFO detail; false = keep details at DEBUG)
STREAM_VERBOSE_LOGS=false

# Stream detection: keep browser exclusive for Studio engagement
# Disable vision stream detection unless a dedicated Chrome debug port is configured
STREAM_VISION_DISABLED=true

# Sprint 3.2: Browser selection for vision detection
# Options: edge (default, prevents Chrome hijacking) | chrome (uses separate port)
# Edge browser prevents conflict with comment engagement on Chrome :9222
# Fallback chain: Edge → Chrome :9223 → Chrome :9222 → HTTP scraping
STREAM_BROWSER_TYPE=edge

# If you re-enable vision stream detection, point it at a separate Chrome instance/port
STREAM_CHROME_PORT=9223

# =============================================
# Notes
# =============================================
# - All sensitive keys should be managed via system environment variables
# - API keys and secrets should never be committed to version control
# - Use the credentials/ directory for storing OAuth tokens and client secrets
# - Follow the Windsurf Protocol for secure configuration management
