# WRE CoT System Configuration
# Source of truth for all feature flags
# Last updated: 2026-02-24

# Sprint 1: ReAct Loop (Gap A)
WRE_REACT_MODE=1
WRE_REACT_MAX_ITER=3
WRE_REACT_FIDELITY=0.90
# Sprint 2: Agentic RAG (Gap F)
WRE_AGENTIC_RAG=1
# Sprint 3: ToT Selection (Gap B)
WRE_TOT_SELECTION=1
WRE_TOT_MAX_BRANCHES=5
# Sprint 3: CodeAct Execution (Gap E)
WRE_CODEACT_ENABLED=1
WRE_CODEACT_STRICT=1
# WRE per-skill scan gate
WRE_SKILL_SCAN_REQUIRED=1
WRE_SKILL_SCAN_ENFORCED=1
WRE_SKILL_SCAN_ALWAYS=0
WRE_SKILL_SCAN_TTL_SEC=900
WRE_SKILL_SCAN_MAX_SEVERITY=medium
# Startup dependency/CVE preflight policy
OPENCLAW_DEP_SECURITY_PREFLIGHT=1
OPENCLAW_DEP_SECURITY_PREFLIGHT_ENFORCED=0
OPENCLAW_DEP_SECURITY_PREFLIGHT_FORCE=0
OPENCLAW_DEP_SECURITY_PREFLIGHT_TTL_SEC=21600
OPENCLAW_DEP_SECURITY_REQUIRE_TOOLS=0
OPENCLAW_DEP_SECURITY_MAX_CRITICAL=0
OPENCLAW_DEP_SECURITY_MAX_HIGH=0
OPENCLAW_DEP_SECURITY_MAX_UNKNOWN=0
OPENCLAW_DEP_SECURITY_CHECK_NODE=1
OPENCLAW_DEP_SECURITY_NODE_LOCK_SCOPE=all
OPENCLAW_DEP_SECURITY_CHECK_RUST=1
# Optional: Pattern Memory DB override
# WRE_PATTERN_MEMORY_DB
# Optional: IronClaw Worker
WRE_ENABLE_IRONCLAW_WORKER=1

# 0102 daemon self-audit loop (adaptive remediation)
OPENCLAW_SELF_AUDIT_ENABLED=1
OPENCLAW_SELF_AUDIT_AUTO_FIX=1
OPENCLAW_SELF_AUDIT_ALLOWED_FIXES=start_ironclaw_gateway,diagnose_microphone_device,verify_dae_event_store
OPENCLAW_SELF_AUDIT_ALLOW_SHELL_START_CMD=0
OPENCLAW_SELF_AUDIT_TELEMETRY=1
OPENCLAW_SELF_AUDIT_ESCALATE_AFTER=3
OPENCLAW_SELF_AUDIT_ESCALATION_WINDOW_SEC=900
OPENCLAW_SELF_AUDIT_ESCALATION_COOLDOWN_SEC=600
OPENCLAW_SELF_AUDIT_ESCALATE_CMD=
OPENCLAW_SELF_AUDIT_ESCALATE_ALLOW_SHELL_CMD=0
OPENCLAW_SELF_AUDIT_INTERVAL_SEC=5
OPENCLAW_SELF_AUDIT_FIX_COOLDOWN_SEC=120
OPENCLAW_SELF_AUDIT_DEDUPE_WINDOW_SEC=120
OPENCLAW_SELF_AUDIT_MAX_READ_BYTES=65536
