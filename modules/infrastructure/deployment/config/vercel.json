{
  "name": "foundups-agent",
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "500mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/holoindex",
      "dest": "/main.py"
    },
    {
      "src": "/api/search",
      "dest": "/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/main.py"
    }
  ],
  "env": {
    "LOCAL_MODEL_ROOT": "E:/LM_studio/models/local",
    "LOCAL_MODEL_TRIAGE_DIR": "E:/LM_studio/models/local/gemma-270m",
    "LOCAL_MODEL_GENERAL_DIR": "E:/LM_studio/models/local/qwen3-4b",
    "LOCAL_MODEL_CODE_DIR": "E:/LM_studio/models/local/qwen-coder-7b",
    "HOLO_QWEN_MODEL": "E:/LM_studio/models/local/qwen-coder-7b",
    "HOLO_QWEN_MAX_TOKENS": "512",
    "HOLO_QWEN_TEMPERATURE": "0.2"
  },
  "functions": {
    "main.py": {
      "maxDuration": 30
    }
  },
  "regions": ["iad1"]
}
